{
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "typescript.tsdk": "./packages/source/node_modules/typescript/lib",
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "vue"],
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "vue.complete.casing.props": "camel",
  "vue.complete.casing.tags": "pascal",
  "cSpell.words": ["bson", "Codegen", "Moraru", "Pinia", "pkgroll", "sagedash", "sageslate", "tailwindcss"],
  "i18n-ally.enabledFrameworks": ["vue"],
  "i18n-ally.localesPaths": ["apps/sight/src/locales"],
  "i18n-ally.extract.autoDetect": true,
  "i18n-ally.extract.keyMaxLength": 80,
  "i18n-ally.keystyle": "nested",
  "i18n-ally.displayLanguage": "en-US"
}
