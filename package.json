{
  "name": "sageslate",
  "version": "0.1.0",
  "description": "Simple VTT",
  "scripts": {
    "generate:graphql:00_codegen": "graphql-codegen-esm",
    "generate:graphql:01_fix-imports": "cd apps/source && pnpm graphql:fix",
    "generate:graphql:02_lint": "cd apps/source && pnpm graphql:lint",
    "generate:graphql": "run-s -l generate:graphql:*",
    "generate": "run-s -l generate:*",
    "dev:generate:graphql": "nodemon --config nodemon.graphql.json",
    "dev:generate": "run-p -l dev:generate:graphql",
    "dev:server": "cd apps/source && pnpm dev",
    "dev:sight": "cd apps/sight && pnpm dev",
    "dev:stone": "cd packages/stone && pnpm dev",
    "dev:tools": "cd packages/tools && pnpm dev",
    "dev": "NODE_ENV=development run-p -l dev:*",
    "lint:sever": "cd apps/source && pnpm lint",
    "lint:sight": "cd apps/sight && pnpm lint",
    "lint:stone": "cd packages/stone && pnpm lint",
    "lint:tools": "cd packages/tools && pnpm lint",
    "lint": "run-s -l lint:*"
  },
  "keywords": [
    "vtt"
  ],
  "license": "MIT",
  "author": "Nicolai Moraru <ceo@nickmessing.com>",
  "private": true,
  "devDependencies": {
    "@eddeee888/gcg-typescript-resolver-files": "^0.7.2",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/plugin-helpers": "^5.0.1",
    "@tsconfig/node20": "^20.1.2",
    "cz-conventional-changelog": "^3.3.0",
    "nodemon": "^3.0.2",
    "npm-run-all2": "^6.1.1",
    "prettier": "^3.2.1",
    "prettier-plugin-tailwindcss": "^0.5.11"
  }
}
