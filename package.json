  "description": "Simple VTT",
  "scripts": {
    "dev:rock": "cd packages/rock && pnpm dev",
    "dev:sight": "cd packages/sight && pnpm dev",
    "dev:source": "cd packages/source && pnpm dev",
    "dev": "run-p -l dev:*",
