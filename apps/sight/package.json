{
  "name": "@sageslate/sight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "keywords": [
    "vtt"
  ],
  "license": "MIT",
  "author": "Nicolai Moraru <ceo@nickmessing.com>",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint:path": "eslint --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint": "pnpm run lint:path .",
    "format": "prettier --write src/",
    "graphql:core:lint": "pnpm run lint:path src/graphql/core/index.ts",
    "graphql:core:fix": "sage-fix-client src/graphql/core/index.ts",
    "graphql:realm:lint": "pnpm run lint:path src/graphql/realm/index.ts",
    "graphql:realm:fix": "sage-fix-client src/graphql/realm/index.ts --realm"
  },
  "dependencies": {
    "@apollo/client": "^3.8.10",
    "@mdi/js": "^7.4.47",
    "@sageslate/stone": "workspace:*",
    "@vue/apollo-composable": "^4.0.0",
    "@vueuse/core": "^10.7.2",
    "@vueuse/shared": "^10.7.2",
    "bson": "^6.2.0",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "pinia": "^2.1.7",
    "vue": "^3.4.15",
    "vue-i18n": "9.9.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.1",
    "@sageslate/eslint-config-standards": "workspace:*",
    "@sageslate/tools": "workspace:*",
    "@tsconfig/node18": "^18.2.2",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.11.5",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.3",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "jsdom": "^23.2.0",
    "less": "^4.2.0",
    "npm-run-all2": "^6.1.1",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "type-fest": "^4.9.0",
    "typescript": "^5.3.3",
    "unplugin-vue-router": "^0.7.0",
    "vite": "^5.0.12",
    "vitest": "^1.2.1",
    "vue-tsc": "^1.8.27"
  }
}
